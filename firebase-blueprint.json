{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Information about a cooperative member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "noAnggota": { "type": "string" },
        "nama": { "type": "string" },
        "alamat": { "type": "string" },
        "noHp": { "type": "string" },
        "tanggalBergabung": { "type": "string" },
        "jenisKelamin": { "type": "string", "enum": ["Laki-laki", "Perempuan"] }
      },
      "required": ["id", "noAnggota", "nama", "tanggalBergabung"]
    },
    "KoperasiSetup": {
      "title": "KoperasiSetup",
      "description": "Setup/profile information of the cooperative.",
      "type": "object",
      "properties": {
        "namaKoperasi": { "type": "string" },
        "slogan": { "type": "string" },
        "alamatKantor": { "type": "string" },
        "noBadanHukum": { "type": "string" },
        "logoUrl": { "type": "string" },
        "jenisBungaPinjaman": { "type": "string", "enum": ["flat", "menurun"] },
        "biayaProvisiPersen": { "type": "number" },
        "jasaSimpananSukarelaPersen": { "type": "number" },
        "kasAwal": { "type": "number" },
        "piutangAwal": { "type": "number" },
        "persediaanWarungAwal": { "type": "number" },
        "inventarisAwal": { "type": "number" },
        "simpananPokokAwal": { "type": "number" },
        "simpananWajibAwal": { "type": "number" },
        "simpananSukarelaAwal": { "type": "number" },
        "modalAwal": { "type": "number" },
        "danaCadanganAwal": { "type": "number" }
      },
      "required": ["namaKoperasi", "slogan", "alamatKantor", "jenisBungaPinjaman", "biayaProvisiPersen", "jasaSimpananSukarelaPersen"]
    },
    "Simpanan": {
      "title": "Simpanan",
      "description": "Savings transactions of members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "anggotaId": { "type": "string" },
        "tanggal": { "type": "string" },
        "jenis": { "type": "string", "enum": ["Pokok", "Wajib", "Sukarela"] },
        "jumlah": { "type": "number" },
        "keterangan": { "type": "string" },
        "transaksiId": { "type": "string" }
      },
      "required": ["id", "anggotaId", "tanggal", "jenis", "jumlah"]
    },
    "Pinjaman": {
      "title": "Pinjaman",
      "description": "Loan application and state.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "anggotaId": { "type": "string" },
        "tanggal": { "type": "string" },
        "nominalPinjaman": { "type": "number" },
        "tenor": { "type": "number" },
        "bungaFlatPersen": { "type": "number" },
        "biayaProvisiPersen": { "type": "number" },
        "provisiDipotong": { "type": "number" },
        "jumlahDiterima": { "type": "number" },
        "status": { "type": "string", "enum": ["Belum Lunas", "Lunas"] },
        "angsuranPokokPerBulan": { "type": "number" },
        "jasaPerBulan": { "type": "number" },
        "totalAngsuranPerBulan": { "type": "number" },
        "totalWajibBayar": { "type": "number" }
      },
      "required": ["id", "anggotaId", "tanggal", "nominalPinjaman", "tenor", "bungaFlatPersen", "status"]
    },
    "Angsuran": {
      "title": "Angsuran",
      "description": "Loan repayment install logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pinjamanId": { "type": "string" },
        "anggotaId": { "type": "string" },
        "tanggal": { "type": "string" },
        "jumlahBayar": { "type": "number" },
        "bulanKe": { "type": "number" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "pinjamanId", "anggotaId", "tanggal", "jumlahBayar", "bulanKe"]
    },
    "PendapatanLain": {
      "title": "PendapatanLain",
      "description": "Other income streams of the cooperative.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tanggal": { "type": "string" },
        "sumber": { "type": "string", "enum": ["warung", "bunga_simpanan", "denda", "lain_lain"] },
        "nominal": { "type": "number" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "tanggal", "sumber", "nominal"]
    },
    "BebanKoperasi": {
      "title": "BebanKoperasi",
      "description": "Expenses incurred by the cooperative.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tanggal": { "type": "string" },
        "kategori": { "type": "string", "enum": ["gaji_karyawan", "listrik", "gaji_pengurus", "gaji_pengawas", "operasional_kantor", "beban_lain"] },
        "nominal": { "type": "number" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "tanggal", "kategori", "nominal"]
    },
    "ManasukaBungaLog": {
      "title": "ManasukaBungaLog",
      "description": "Calculated interest dividend records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "anggotaId": { "type": "string" },
        "bulanTahun": { "type": "string" },
        "totalSimpanan": { "type": "number" },
        "bungaPersen": { "type": "number" },
        "jumlahApresiasi": { "type": "number" },
        "statusNotifikasi": { "type": "string", "enum": ["Belum Kirim", "Terkirim"] },
        "tanggalKalkulasi": { "type": "string" }
      },
      "required": ["id", "anggotaId", "bulanTahun", "totalSimpanan", "bungaPersen", "jumlahApresiasi", "statusNotifikasi"]
    },
    "Pembelian": {
      "title": "Pembelian",
      "description": "Stock purchase log records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tanggal": { "type": "string" },
        "namaBarang": { "type": "string" },
        "kategori": { "type": "string", "enum": ["persediaan_warung", "seragam", "persediaan_barang", "inventaris", "lain_lain"] },
        "kuantitas": { "type": "number" },
        "hargaSatuan": { "type": "number" },
        "totalHarga": { "type": "number" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "tanggal", "namaBarang", "kategori", "kuantitas", "hargaSatuan", "totalHarga"]
    },
    "PiutangWarung": {
      "title": "PiutangWarung",
      "description": "Warung cooperative accounts receivable/debts sync log.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "anggotaId": { "type": "string" },
        "tanggal": { "type": "string" },
        "jenis": { "type": "string", "enum": ["hutang_baru", "pelunasan"] },
        "nominal": { "type": "number" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "anggotaId", "tanggal", "jenis", "nominal"]
    },
    "Pengumuman": {
      "title": "Pengumuman",
      "description": "Custom announcement created by administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tanggal": { "type": "string" },
        "judul": { "type": "string" },
        "konten": { "type": "string" },
        "isUrgent": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Aktif", "Nonaktif"] }
      },
      "required": ["id", "tanggal", "judul", "konten", "isUrgent", "status"]
    }
  },
  "firestore": {
    "setup": {
      "schema": "KoperasiSetup",
      "description": "Saves cooperative global settings profile doc."
    },
    "members": {
      "schema": "Member",
      "description": "Table for members."
    },
    "simpanan": {
      "schema": "Simpanan",
      "description": "Saving logs."
    },
    "pinjaman": {
      "schema": "Pinjaman",
      "description": "Pinjaman requests and details."
    },
    "angsuran": {
      "schema": "Angsuran",
      "description": "Repayment installations."
    },
    "income": {
      "schema": "PendapatanLain",
      "description": "Income logs."
    },
    "expenses": {
      "schema": "BebanKoperasi",
      "description": "Expense logs."
    },
    "manasukaLogs": {
      "schema": "ManasukaBungaLog",
      "description": "Interest calculations."
    },
    "pembelian": {
      "schema": "Pembelian",
      "description": "Inventory purchase ledger."
    },
    "piutang_warung": {
      "schema": "PiutangWarung",
      "description": "Warung/Kantin receivables."
    },
    "announcements": {
      "schema": "Pengumuman",
      "description": "Announcements displayed on home dashboard."
    }
  }
}
