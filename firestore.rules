rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default block
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Setup Collection
    match /setup/info {
      allow read: if true;
      allow write: if true; // Teller can update setup details
    }

    // Members Collection
    match /members/{memberId} {
      allow read: if true;
      allow write: if isValidId(memberId);
    }

    // Simpanan Collection
    match /simpanan/{simpananId} {
      allow read: if true;
      allow write: if isValidId(simpananId);
    }

    // Pinjaman Collection
    match /pinjaman/{pinjamanId} {
      allow read: if true;
      allow write: if isValidId(pinjamanId);
    }

    // Angsuran Collection
    match /angsuran/{angsuranId} {
      allow read: if true;
      allow write: if isValidId(angsuranId);
    }

    // Income Collection
    match /income/{incomeId} {
      allow read: if true;
      allow write: if isValidId(incomeId);
    }

    // Expenses Collection
    match /expenses/{expenseId} {
      allow read: if true;
      allow write: if isValidId(expenseId);
    }

    // ManasukaLogs Collection
    match /manasukaLogs/{logId} {
      allow read: if true;
      allow write: if isValidId(logId);
    }

    // Pembelian Collection
    match /pembelian/{pembelianId} {
      allow read: if true;
      allow write: if isValidId(pembelianId);
    }

    // Piutang Warung Collection
    match /piutang_warung/{piutangWarungId} {
      allow read: if true;
      allow write: if isValidId(piutangWarungId);
    }

    // Announcements Collection
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isValidId(announcementId);
    }
  }
}
